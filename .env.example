# ============================================================================
# Core Structure - Environment Variables Template
# ============================================================================
# Copy this file to .env and adjust values for your environment.

# ============================================================================
# 1. LOCAL OCR (Required for basic desktop use without remote backend)
# ============================================================================
CHANDRA_BASE_URL=http://localhost:1234
QWEN_BASE_URL=http://localhost:1234

# ============================================================================
# 2. REMOTE OCR SERVER
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REMOTE_OCR_DATA_DIR=/data
OCR_CONFIG_PATH=services/remote_ocr/server/config.yaml
LOG_LEVEL=INFO
LOG_FORMAT=plain

# ============================================================================
# 3. SUPABASE (Tree and Annotations)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ============================================================================
# 4. CLOUDFLARE R2 (Storage)
# ============================================================================
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=rd1
R2_PUBLIC_URL=https://pub-xxxxxx.r2.dev

# ============================================================================
# 5. MISCELLANEOUS
# ============================================================================
ENABLE_PERFORMANCE_MONITOR=false
